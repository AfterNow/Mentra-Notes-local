{
    "name": "MentraApp-DevContainer",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "runArgs": [
        "--gpus=all",
        "--ipc=host",
        "--ulimit=stack=67108864",
        "--ulimit=memlock=-1",
        "--name=mentra-note-gemma4"
    ],
    "forwardPorts": [8084, 6274, 6277],  // Ollama and auoth google + MCP Inspector
    "containerEnv": {
        "TZ": "America/Los_Angeles" // Set timezone
    },
    "remoteUser": "ubuntu",
    "mounts": [
        "source=/home/afternow/docker/Mentra-Notes-local,target=/workspace,type=bind,consistency=cached"
    ]
} 