# =============================================================================
# Mentra Notes - Docker Deployment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# MentraOS Configuration (REQUIRED)
# Get these from https://console.mentra.glass
# -----------------------------------------------------------------------------

PACKAGE_NAME=com.mentra.notes
MENTRAOS_API_KEY=your_api_key_here

# -----------------------------------------------------------------------------
# Security (REQUIRED - change these!)
# -----------------------------------------------------------------------------

# Cookie encryption secret (generate with: openssl rand -hex 32)
COOKIE_SECRET=change_me_to_a_random_string

# MongoDB credentials
MONGO_USER=admin
MONGO_PASSWORD=change_me_to_a_secure_password
MONGO_DB=ainotes

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# Port to expose (default: 3000)
PORT=3000

# -----------------------------------------------------------------------------
# AI Provider Configuration
# -----------------------------------------------------------------------------

# Provider: llamacpp, ollama, gemini, anthropic, openai
# For self-hosted, use llamacpp or ollama
AGENT_PROVIDER=llamacpp

# llama.cpp server URL (if running on host machine)
LLAMACPP_BASE_URL=http://host.docker.internal:8080
LLAMACPP_MODEL=local-model

# Ollama server URL (if using Ollama instead)
# AGENT_PROVIDER=ollama
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL_FAST=llama3.1
# OLLAMA_MODEL_SMART=llama3.1:70b

# External llama.cpp server (if running on another machine)
# LLAMACPP_BASE_URL=http://192.168.1.185:30000

# -----------------------------------------------------------------------------
# Storage Configuration
# -----------------------------------------------------------------------------

# Storage provider: local or r2
STORAGE_PROVIDER=local

# For Cloudflare R2 (optional - cloud storage)
# STORAGE_PROVIDER=r2
# CLOUDFLARE_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# CLOUDFLARE_R2_BUCKET_NAME=mentra-notes
# CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_key

# -----------------------------------------------------------------------------
# Privacy Configuration
# -----------------------------------------------------------------------------

# Local-only mode: prevents any cloud LLM providers from being used
LOCAL_ONLY_MODE=false

# Analytics: disabled by default for privacy
ENABLE_ANALYTICS=false

# -----------------------------------------------------------------------------
# Cloudflare Tunnel (optional - for HTTPS without port forwarding)
# -----------------------------------------------------------------------------

# Get token from https://one.dash.cloudflare.com/
# Create tunnel -> Configure -> Get token
# CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here

# -----------------------------------------------------------------------------
# Email (optional - for sharing notes via email)
# -----------------------------------------------------------------------------

# RESEND_API_KEY=re_your_resend_api_key
